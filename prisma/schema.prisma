// Prisma Schema
// 文件：prisma/schema.prisma
// 用途：定義資料庫結構與模型

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 使用者與驗證碼
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 一對多關聯
  otpCodes   OtpCode[]
  quizRecords QuizRecord[]
}

/// Email 驗證碼（OTP），有過期時間
model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  /// 驗證碼過期時間
  expiresAt DateTime
  /// 是否已使用
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  @@index([email, code])
}

// ============================================
// 測驗記錄
// ============================================

model QuizRecord {
  id        String   @id @default(cuid())
  /// 完整作答明細（JSON 字串）
  answers   String
  score     Int
  total     Int
  percentage Int
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, createdAt])
}
